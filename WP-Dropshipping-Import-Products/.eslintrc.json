{
    "extends": [ "plugin:@wordpress/eslint-plugin/recommended" ],
    "env": {
        "browser": true,
        "jquery": true,
        "es2020": true
    },
    "globals": {
        "dipAdmin": "readonly",
        "wp": "readonly"
    },
    "rules": {
        "no-console": "warn",
        "no-unused-vars": "warn",
        "camelcase": "warn",
        "@wordpress/no-unsafe-wp-apis": "warn"
    }
}
